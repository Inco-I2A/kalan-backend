{
    "name": "kalan-backend",
    "version": "1.1.0",
    "description": "KALAN — Backend API pour flashcards éducatives au Burkina Faso",
    "main": "server.js",
    "scripts": {
      "start": "node server.js",
      "dev": "nodemon server.js",
      "test": "NODE_ENV=test jest --coverage",
      "test:watch": "NODE_ENV=test jest --watch"
    },
    "keywords": [
      "education",
      "flashcards",
      "burkina-faso",
      "offline-first",
      "ocr"
    ],
    "author": "Équipe KALAN",
    "license": "MIT",
    "dependencies": {
      "compression": "^1.7.4",
      "cors": "^2.8.5",
      "dotenv": "^16.4.5",
      "express": "^4.19.2",
      "express-rate-limit": "^7.2.0",
      "helmet": "^7.1.0",
      "jsonwebtoken": "^9.0.2",
      "multer": "^2.1.1",
      "pdf-parse": "^2.4.5",
      "sqlite3": "^5.1.7",
      "swagger-jsdoc": "^6.2.8",
      "swagger-ui-express": "^5.0.0",
      "uuid": "^9.0.1"
    },
    "devDependencies": {
      "jest": "^29.7.0",
      "nodemon": "^3.1.0",
      "supertest": "^7.0.0"
    },
    "jest": {
      "testEnvironment": "node",
      "verbose": true,
      "maxWorkers": 1,
      "collectCoverageFrom": [
        "src/**/*.js",
        "!src/config/database.js"
      ],
      "coverageDirectory": "coverage",
      "testMatch": [
        "**/tests/**/*.test.js"
      ]
    }
  }